<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Smart Indoor Pro - V6.0 Full</title>

    <script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-firestore-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-auth-compat.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/interactjs/dist/interact.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">

    <style>
         :root {
            --primary: #e63946;
            --gold: #ffb703;
            --accent: #00b4ff;
            --dark: #0a0a0a;
            --panel-w: 360px;
        }
        
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        
        body {
            background: #000;
            color: #fff;
            font-family: 'Inter', sans-serif;
            overflow: hidden;
            height: 100vh;
        }
        /* --- PLAYER AREA --- */
        
        #main-container {
            display: flex;
            height: 100vh;
            width: 100vw;
        }
        
        #stage {
            flex-grow: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            background: radial-gradient(circle, #1a1a1a 0%, #000 100%);
            position: relative;
            overflow: hidden;
        }
        
        #master-screen {
            position: relative;
            transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
        }
        
        #viewport {
            width: 1920px;
            height: 1080px;
            background-color: #111;
            background-size: cover;
            background-position: center;
            position: relative;
            overflow: hidden;
            box-shadow: 0 0 100px rgba(0, 0, 0, 0.5);
        }
        
        #viewport.vertical {
            width: 1080px;
            height: 1920px;
        }
        
        #master-screen.rotated {
            transform: rotate(90deg);
        }
        
        #dark-overlay {
            position: absolute;
            inset: 0;
            background: #000;
            pointer-events: none;
            z-index: 5;
            transition: opacity 0.5s;
        }
        /* --- ELEMENTOS --- */
        
        .element {
            position: absolute;
            z-index: 10;
            cursor: default;
            user-select: none;
            will-change: transform;
            transform-origin: top left;
        }
        
        .editor-active .element {
            cursor: move;
            outline: 2px dashed rgba(255, 255, 255, 0.3);
            outline-offset: 5px;
        }
        
        .txt {
            font-weight: 900;
            text-transform: uppercase;
            line-height: 1;
            white-space: nowrap;
        }
        
        .element img {
            width: 100%;
            height: auto;
            display: block;
        }
        /* --- EDITOR PANEL --- */
        
        #editor-panel {
            width: var(--panel-w);
            background: var(--dark);
            border-left: 2px solid #222;
            display: none;
            flex-direction: column;
            overflow-y: auto;
            padding: 20px;
            z-index: 1000;
        }
        
        body.editor-active #editor-panel {
            display: flex;
        }
        
        .section {
            background: #151515;
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 15px;
            border: 1px solid #222;
        }
        
        h3 {
            font-size: 12px;
            color: var(--gold);
            text-transform: uppercase;
            margin-bottom: 10px;
            letter-spacing: 1px;
        }
        
        label {
            font-size: 10px;
            color: #777;
            display: block;
            margin-top: 10px;
        }
        
        input,
        select {
            width: 100%;
            background: #000;
            border: 1px solid #333;
            color: #fff;
            padding: 10px;
            border-radius: 6px;
            margin-top: 5px;
            font-size: 13px;
        }
        
        .btn {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 10px;
            transition: 0.3s;
        }
        
        .btn-primary {
            background: var(--primary);
            color: white;
        }
        
        .btn-save {
            background: #2ecc71;
            color: white;
            margin-top: 20px;
        }
        
        .btn-outline {
            background: #222;
            color: #ccc;
            font-size: 11px;
        }
        /* --- UI FIXA --- */
        
        #config-trigger {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 50px;
            height: 50px;
            background: rgba(0, 0, 0, 0.6);
            border: 1px solid #333;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 2000;
            font-size: 20px;
        }
        
        #status-bar {
            position: fixed;
            top: 15px;
            left: 15px;
            background: rgba(0, 0, 0, 0.8);
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 11px;
            color: #00b4ff;
            z-index: 3000;
            border: 1px solid #222;
        }
        
        .anim-entry {
            animation: slideIn 0.8s ease-out forwards;
        }
        
        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translate(var(--tx), calc(var(--ty) + 40px));
            }
            to {
                opacity: 1;
                transform: translate(var(--tx), var(--ty));
            }
        }
    </style>
</head>

<body>

    <div id="status-bar">Sincronizando...</div>
    <div id="config-trigger" onclick="handleAuthToggle()">⚙️</div>

    <div id="main-container">
        <div id="stage">
            <div id="master-screen">
                <div id="viewport">
                    <div id="dark-overlay"></div>

                    <div id="el-logo" class="element" data-key="pos_logo"><img id="v-logo"></div>
                    <div id="el-prod" class="element" data-key="pos_prod"><img id="v-prod"></div>

                    <div id="el-title" class="element" data-key="pos_title">
                        <div id="v-title" class="txt">Produto</div>
                    </div>

                    <div id="el-desc" class="element" data-key="pos_desc">
                        <div id="v-desc" class="txt" style="font-weight:400; text-transform:none;">Descrição aqui</div>
                    </div>

                    <div id="el-price" class="element" data-key="pos_price">
                        <div id="v-price" class="txt" style="color:var(--gold)">R$ 0,00</div>
                    </div>
                </div>
            </div>
        </div>

        <aside id="editor-panel">
            <h2 style="font-size: 18px; margin-bottom: 5px;">Smart Indoor <span style="color:var(--primary)">PRO</span></h2>
            <p id="user-info" style="font-size: 10px; color: #555; margin-bottom: 20px;">Device ID: ---</p>

            <div class="section">
                <h3>Navegação</h3>
                <div style="display: flex; gap: 10px; align-items: center; justify-content: space-between;">
                    <button class="btn btn-outline" onclick="changeSlide(-1)">◀</button>
                    <span id="slide-index">1 / 1</span>
                    <button class="btn btn-outline" onclick="changeSlide(1)">▶</button>
                </div>
                <button class="btn btn-outline" style="background:var(--accent); color:black; border:none;" onclick="cloneSlide()">+ Clonar Slide</button>
            </div>

            <div class="section">
                <h3>Conteúdo</h3>
                <label>Título do Produto</label>
                <input type="text" id="in-title" oninput="updateLive('nome', this.value)">
                <label>Descrição</label>
                <input type="text" id="in-desc" oninput="updateLive('descricao', this.value)">
                <label>Preço</label>
                <input type="text" id="in-price" oninput="updateLive('preco', this.value)">
            </div>

            <div class="section">
                <h3>Mídia (URL)</h3>
                <label>Imagem do Produto</label>
                <input type="text" id="in-img" oninput="updateLive('url', this.value)">
                <label>Fundo (Background)</label>
                <input type="text" id="in-bg" oninput="updateLive('bg', this.value)">
                <label>Escurecer Fundo</label>
                <input type="range" min="0" max="1" step="0.1" id="in-dark" oninput="updateLive('dark_intensity', parseFloat(this.value))">
            </div>

            <div class="section">
                <h3>Aparência e Estilo</h3>
                <label>Cor Título / Tamanho</label>
                <div style="display:flex; gap:5px;">
                    <input type="color" id="in-color-t" oninput="updateLive('color_t', this.value)" style="width:50px;">
                    <input type="range" min="20" max="300" id="in-size-t" oninput="updateLive('size_t', parseInt(this.value))">
                </div>
                <label>Tamanho da Imagem</label>
                <input type="range" min="100" max="1500" id="in-w-prod" oninput="updateLive('w_prod', parseInt(this.value))">
            </div>

            <div class="section">
                <h3>Exibição</h3>
                <button class="btn btn-outline" onclick="toggleOrientation()">🔄 Alternar H / V</button>
                <button class="btn btn-outline" onclick="toggleRotatePreview()">📐 Girar Preview 90°</button>
                <label>Duração (Segundos)</label>
                <input type="number" id="in-duration" oninput="updateLive('duracao', parseInt(this.value))">
            </div>

            <button class="btn btn-save" onclick="saveToFirebase()">💾 SALVAR NO DISPOSITIVO</button>
            <button class="btn btn-outline" onclick="deleteCurrentSlide()" style="color: #e63946; border-color: #441111;">Excluir Slide</button>
            <button class="btn btn-outline" onclick="logout()" style="margin-top: 30px; opacity: 0.5;">Sair do Editor</button>
        </aside>
    </div>

    <script>
        // --- CONFIGURAÇÃO ---
        const firebaseConfig = {
            apiKey: "AIzaSyDiTbWSlcKpsPEtEzPkSU0jHZkfcAg5fNU",
            authDomain: "newsmartonapp.firebaseapp.com",
            projectId: "newsmartonapp",
            storageBucket: "newsmartonapp.firebasestorage.app",
            messagingSenderId: "1096968028299",
            appId: "1:1096968028299:web:f3a9e48db108afbbb7548e"
        };

        firebase.initializeApp(firebaseConfig);
        const db = firebase.firestore();
        const auth = firebase.auth();

        let state = {
            slides: [],
            current: 0,
            isEditor: false,
            scale: 1,
            ownerUid: '',
            userLogo: '',
            deviceId: new URLSearchParams(window.location.search).get('id') || localStorage.getItem('lastId'),
            timer: null
        };

        const ADMIN_ID = "DrzBYJWuNAOoAIRGWfrsKdVFhYr2";

        // --- INICIALIZAÇÃO ---
        if (state.deviceId) {
            localStorage.setItem('lastId', state.deviceId);
            document.getElementById('user-info').innerText = `ID: ${state.deviceId}`;
            initRealtime();
        } else {
            document.getElementById('status-bar').innerText = "Erro: ID ausente na URL";
        }

        function initRealtime() {
            db.collectionGroup('dispositivos').onSnapshot(snap => {
                const doc = snap.docs.find(d => d.id === state.deviceId);
                if (doc) {
                    const data = doc.data();
                    state.ownerUid = doc.ref.parent.parent.id;
                    state.userLogo = data.logoUrl || '';

                    const remoteSlides = (data.config_menu && data.config_menu.slides) ? data.config_menu.slides : [getDefaultTemplate()];

                    // Só atualiza se não estiver editando para não perder alterações locais
                    if (!state.isEditor) {
                        state.slides = remoteSlides;
                        startPlayer();
                    }
                    document.getElementById('status-bar').style.display = 'none';
                }
            });
        }

        function getDefaultTemplate() {
            return {
                nome: "NOVO PRODUTO",
                descricao: "Descrição do item",
                preco: "19,90",
                url: "",
                bg: "",
                dark_intensity: 0.4,
                color_t: "#ffffff",
                size_t: 100,
                color_p: "#ffb703",
                size_p: 180,
                w_prod: 700,
                orientacao: "horizontal",
                duracao: 8,
                pos_title: {
                    x: 100,
                    y: 150
                },
                pos_desc: {
                    x: 100,
                    y: 300
                },
                pos_price: {
                    x: 100,
                    y: 550
                },
                pos_prod: {
                    x: 1000,
                    y: 100
                },
                pos_logo: {
                    x: 50,
                    y: 50
                }
            };
        }

        // --- CORE ENGINE ---
        function render() {
            const s = state.slides[state.current];
            if (!s) return;

            const vp = document.getElementById('viewport');

            // Orientação
            vp.className = s.orientacao === 'vertical' ? 'vertical' : '';
            vp.style.backgroundImage = s.bg ? `url('${s.bg}')` : 'none';
            document.getElementById('dark-overlay').style.opacity = s.dark_intensity || 0;

            // Conteúdo
            document.getElementById('v-title').innerText = s.nome;
            document.getElementById('v-title').style.color = s.color_t;
            document.getElementById('v-title').style.fontSize = s.size_t + "px";

            document.getElementById('v-desc').innerText = s.descricao;
            document.getElementById('v-price').innerText = s.preco.includes('R$') ? s.preco : "R$ " + s.preco;
            document.getElementById('v-price').style.fontSize = (s.size_p || 180) + "px";

            const imgProd = document.getElementById('v-prod');
            imgProd.src = s.url || '';
            imgProd.parentElement.style.width = (s.w_prod || 700) + "px";

            const imgLogo = document.getElementById('v-logo');
            imgLogo.src = state.userLogo || '';
            imgLogo.parentElement.style.width = "250px";

            // Posicionamento
            Object.keys(s).forEach(key => {
                if (key.startsWith('pos_')) {
                    const el = document.getElementById(key.replace('pos_', 'el-'));
                    if (el) {
                        el.style.setProperty('--tx', `${s[key].x}px`);
                        el.style.setProperty('--ty', `${s[key].y}px`);
                        el.style.transform = `translate(${s[key].x}px, ${s[key].y}px)`;

                        // Animação de entrada (apenas se não for editor)
                        if (!state.isEditor) {
                            el.classList.remove('anim-entry');
                            void el.offsetWidth;
                            el.classList.add('anim-entry');
                        }
                    }
                }
            });

            if (state.isEditor) syncPanelInputs();
            applyScaling();
        }

        function applyScaling() {
            const stage = document.getElementById('stage');
            const master = document.getElementById('master-screen');
            const vp = document.getElementById('viewport');

            const isRotated = master.classList.contains('rotated');
            const isVertical = vp.classList.contains('vertical');

            const availableW = stage.offsetWidth - 60;
            const availableH = stage.offsetHeight - 60;

            const contentW = isVertical ? 1080 : 1920;
            const contentH = isVertical ? 1920 : 1080;

            // Se rotacionado no preview, invertemos as dimensões de destino
            const targetW = isRotated ? contentH : contentW;
            const targetH = isRotated ? contentW : contentH;

            state.scale = Math.min(availableW / targetW, availableH / targetH);
            vp.style.transform = `scale(${state.scale})`;
        }

        // --- PLAYBACK CONTROLS ---
        function startPlayer() {
            clearTimeout(state.timer);
            render();
            if (!state.isEditor && state.slides.length > 1) {
                const duration = (state.slides[state.current].duracao || 8) * 1000;
                state.timer = setTimeout(() => {
                    state.current = (state.current + 1) % state.slides.length;
                    startPlayer();
                }, duration);
            }
        }

        // --- EDITOR ACTIONS ---
        function updateLive(field, value) {
            state.slides[state.current][field] = value;
            render();
        }

        function toggleOrientation() {
            const s = state.slides[state.current];
            s.orientacao = s.orientacao === 'vertical' ? 'horizontal' : 'vertical';
            render();
        }

        function toggleRotatePreview() {
            document.getElementById('master-screen').classList.toggle('rotated');
            setTimeout(applyScaling, 100);
        }

        function changeSlide(dir) {
            state.current = (state.current + dir + state.slides.length) % state.slides.length;
            render();
        }

        function cloneSlide() {
            const clone = JSON.parse(JSON.stringify(state.slides[state.current]));
            state.slides.push(clone);
            state.current = state.slides.length - 1;
            render();
        }

        function deleteCurrentSlide() {
            if (state.slides.length > 1 && confirm("Excluir este slide permanentemente?")) {
                state.slides.splice(state.current, 1);
                state.current = 0;
                render();
            }
        }

        function syncPanelInputs() {
            const s = state.slides[state.current];
            document.getElementById('slide-index').innerText = `${state.current + 1} / ${state.slides.length}`;
            document.getElementById('in-title').value = s.nome;
            document.getElementById('in-desc').value = s.descricao;
            document.getElementById('in-price').value = s.preco;
            document.getElementById('in-img').value = s.url;
            document.getElementById('in-bg').value = s.bg;
            document.getElementById('in-dark').value = s.dark_intensity;
            document.getElementById('in-color-t').value = s.color_t;
            document.getElementById('in-size-t').value = s.size_t;
            document.getElementById('in-w-prod').value = s.w_prod;
            document.getElementById('in-duration').value = s.duracao;
        }

        // --- DRAG SYSTEM (Interact.js) ---
        interact('.element').draggable({
            listeners: {
                move(event) {
                    if (!state.isEditor) return;
                    const key = event.target.dataset.key;
                    const s = state.slides[state.current];

                    // Importante: dividir o deslocamento pela escala para manter precisão
                    s[key].x += event.dx / state.scale;
                    s[key].y += event.dy / state.scale;

                    render();
                }
            }
        });

        // --- AUTH & DATA SYNC ---
        async function handleAuthToggle() {
            const user = auth.currentUser;
            if (user && (user.uid === state.ownerUid || user.uid === ADMIN_ID)) {
                toggleEditorMode();
            } else {
                const email = prompt("Email Admin:");
                const pass = prompt("Senha:");
                if (email && pass) {
                    try {
                        await auth.signInWithEmailAndPassword(email, pass);
                        toggleEditorMode();
                    } catch (e) {
                        alert("Acesso negado.");
                    }
                }
            }
        }

        function toggleEditorMode() {
            state.isEditor = !state.isEditor;
            document.body.classList.toggle('editor-active');
            if (state.isEditor) {
                clearTimeout(state.timer);
                render();
            } else {
                startPlayer();
            }
            setTimeout(applyScaling, 100);
        }

        async function saveToFirebase() {
            const btn = document.querySelector('.btn-save');
            btn.innerText = "⏳ SALVANDO...";
            try {
                const snap = await db.collectionGroup('dispositivos').get();
                const doc = snap.docs.find(d => d.id === state.deviceId);
                if (doc) {
                    await doc.ref.update({
                        "config_menu.slides": state.slides,
                        "config_menu.lastUpdate": firebase.firestore.FieldValue.serverTimestamp()
                    });
                    alert("Menu atualizado com sucesso!");
                }
            } catch (e) {
                alert("Erro ao salvar: " + e.message);
            }
            btn.innerText = "💾 SALVAR NO DISPOSITIVO";
        }

        function logout() {
            auth.signOut().then(() => location.reload());
        }

        window.addEventListener('resize', applyScaling);
    </script>
</body>

</html>
